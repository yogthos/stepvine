;; Widget showcase — a single document exercising every widget in the library,
;; presented as a re-com-style gallery (sidebar of categories + component
;; panels). Also a comprehensive smoke test. Reactivity is demonstrated by a
;; greeting reaction (over :name) and a rating category + conditional alert
;; driven by the slider.
{:id :showcase
 :title "Widget Showcase"
 :version 1

 :data
 {:model
  [[:name      {:id :name      :type :string}]
   [:bio       {:id :bio       :type :string}]
   [:age       {:id :age       :type :number}]
   [:color     {:id :color     :type :string}]
   [:size      {:id :size      :type :string}]
   [:plan      {:id :plan      :type :string}]
   [:tool      {:id :tool      :type :string}]
   [:agree     {:id :agree     :type :boolean}]
   [:rating    {:id :rating    :type :number}]
   [:birthday  {:id :birthday  :type :string}]
   [:meeting   {:id :meeting   :type :string}]
   [:fruit     {:id :fruit     :type :string}]
   [:secret    {:id :secret    :type :string}]
   [:progress  {:id :progress  :type :number}]
   [:tab       {:id :tab       :type :string}]
   [:skills    {:id :skills    :type :array}]
   [:topics    {:id :topics    :type :array}]
   [:people
    {:id :people :collection? true :index-id :pid
     :schema {:model [[:pid   {:id :pid}]
                      [:first {:id :first :type :string}]
                      [:last  {:id :last  :type :string}]
                      [:full  {:id :full  :type :string}]]
              :events [{:id :calc-full :inputs [:first :last] :outputs [:full]
                        :handler (fn [{{:keys [first last]} :inputs}]
                                   {:full (str (or first "") (when (and first last) " ") (or last ""))})}]}}]
   [:tasks
    {:id :tasks :collection? true :index-id :tid
     :schema {:model [[:tid      {:id :tid}]
                      [:title    {:id :title    :type :string}]
                      [:priority {:id :priority :type :number}]]}}]]

  :reactions
  [{:id :greeting :args [:name]
    :fn (fn [n] (if (seq (str n)) (str "Hello, " n "!") "Enter your name above."))}
   {:id :rating-label :args [:rating]
    :fn (fn [r] (cond (nil? r) "n/a" (< r 3) "low" (< r 7) "medium" :else "high"))}
   {:id :high-rating? :args [:rating] :fn (fn [r] (>= (or r 0) 7))}
   {:id :tab-overview? :args [:tab] :fn (fn [t] (or (nil? t) (= t "overview")))}
   {:id :tab-details?  :args [:tab] :fn (fn [t] (= t "details"))}
   ;; drives the chart: a JSON series derived from the rating slider, so the
   ;; chart redraws live as you drag it (signal name chart_data = $chart_data,
   ;; which the :chart widget reads as <id>_data).
   {:id :chart-data :args [:rating]
    :fn (fn [r] (let [b (or r 5)]
                  (str "[" b "," (* 2 b) "," (max 1 (dec b)) "," (+ b 3) "," b "]")))}]}

 :exports
 {:summary {:label "Export summary"
            :template {:name :name :age :age :color :color :rating :rating
                       :category :rating-label}}}

 :views
 {:default
  {:title "Widget Showcase"
   :opts  {:widget-namespaces {"c" "stepvine.components"}}
   :markup
   [:c/form {}
    [:div.sv-shell

     [:aside.sv-sidebar
      [:div.sv-brand "▦ Stepvine widgets"]
      [:ul.sv-nav
       [:li [:a {:href "#sec-text"}     "Text & input"]]
       [:li [:a {:href "#sec-choices"}  "Choices"]]
       [:li [:a {:href "#sec-ranges"}   "Ranges & dates"]]
       [:li [:a {:href "#sec-multi"}    "Multi-selection"]]
       [:li [:a {:href "#sec-display"}  "Display & reactivity"]]
       [:li [:a {:href "#sec-nav"}      "Tabs & layout"]]
       [:li [:a {:href "#sec-feedback"} "Feedback"]]
       [:li [:a {:href "#sec-overlays"} "Overlays"]]
       [:li [:a {:href "#sec-viz"}      "Visualization"]]
       [:li [:a {:href "#sec-people"}   "Collection"]]
       [:li [:a {:href "#sec-table"}    "Table"]]
       [:li [:a {:href "#sec-actions"}  "Actions"]]]]

     [:main.sv-main
      [:header.sv-hero
       [:h1 "Widget gallery"]
       [:p "Every Stepvine widget, live. The server owns all state — every edit "
        "recomputes on the server and broadcasts to all viewers over SSE."]]

      [:section#sec-text.sv-panel
       [:h2 "Text & input" [:span.sv-kw ":input-field  :textarea  :typeahead"]]
       [:p.sv-desc "Two-way-bound text/number inputs, multi-line text, and datalist autocomplete."]
       [:div.sv-demo
        [:c/input-field {:id :name :label "Name"}]
        [:p "Greeting: " [:c/label {:rxn :greeting}]]
        [:c/input-field {:id :age :label "Age"}]
        [:c/textarea {:id :bio :label "Bio" :rows 3 :placeholder "About you…"}]
        [:c/typeahead {:id :fruit :label "Fruit" :placeholder "Start typing…"
                       :options [["Apple" "apple"] ["Banana" "banana"] ["Cherry" "cherry"]]}]
        [:c/input-password {:id :secret :label "Password"}]]]

      [:section#sec-choices.sv-panel
       [:h2 "Choices" [:span.sv-kw ":dropdown  :radio  :selections  :menu  :checkbox"]]
       [:p.sv-desc "Single- and multi-select controls in several shapes."]
       [:div.sv-demo
        [:c/dropdown {:id :color :label "Favorite color"
                      :options [["Red" "red"] ["Green" "green"] ["Blue" "blue"]]}]
        [:c/radio {:id :size :label "Size" :stacked true
                   :options [["Small" "s"] ["Medium" "m"] ["Large" "l"]]}]
        [:c/selections {:id :plan :label "Plan"
                        :options [["Free" "free"] ["Pro" "pro"] ["Team" "team"]]}]
        [:c/menu {:id :tool :label "Tool"
                  :options [["Pen" "pen"] ["Brush" "brush"] ["Eraser" "eraser"]]}]
        [:c/checkbox {:id :agree :label "I agree to the terms"}]]]

      [:section#sec-ranges.sv-panel
       [:h2 "Ranges & dates" [:span.sv-kw ":slider  :date-picker  :input-time"]]
       [:p.sv-desc "A range slider plus native date and time pickers."]
       [:div.sv-demo
        [:c/slider {:id :rating :label "Rating" :min 0 :max 10 :step 1}]
        [:c/date-picker {:id :birthday :label "Birthday"}]
        [:c/input-time {:id :meeting :label "Meeting time"}]]]

      [:section#sec-multi.sv-panel
       [:h2 "Multi-selection" [:span.sv-kw ":selection-list  :multi-select  :tree-select"]]
       [:p.sv-desc "Array-bound controls. Selected state is reactive over the signal, so picks sync across viewers with no re-render."]
       [:div.sv-demo
        [:c/selection-list {:id :skills :label "Skills"
                            :options [["Clojure" "clj"] ["Rust" "rust"]
                                      ["Python" "py"] ["TypeScript" "ts"]]}]
        [:c/multi-select {:id :skills :label "Pick skills"
                          :options [["Clojure" "clj"] ["Rust" "rust"]
                                    ["Python" "py"] ["TypeScript" "ts"]]}]
        [:c/tree-select {:id :topics :label "Topics"
                         :nodes [{:label "Backend" :open? true
                                  :children [{:label "Databases" :value "db"}
                                             {:label "Caching" :value "cache"}]}
                                 {:label "Frontend"
                                  :children [{:label "Reactivity" :value "rx"}
                                             {:label "Styling" :value "css"}]}]}]]]

      [:section#sec-display.sv-panel
       [:h2 "Display & reactivity" [:span.sv-kw ":label  :value  :show  :alert"]]
       [:p.sv-desc "Signal-bound text and a conditional alert. The slider above drives both — try it."]
       [:div.sv-demo
        [:p "Rating category: " [:c/label {:rxn :rating-label}]]
        [:c/show {:when :high-rating?}
         [:c/alert {:class "alert-success" :label "That's a high rating — thank you!"}]]]]

      [:section#sec-nav.sv-panel
       [:h2 "Tabs & layout" [:span.sv-kw ":tabs  :h-box  :v-box  :title  :paragraph  :hyperlink"]]
       [:p.sv-desc "A tab strip drives a signal; conditional panels react to it. Flex layout primitives arrange content."]
       [:div.sv-demo
        [:c/tabs {:id :tab :variant :horizontal
                  :tabs [["Overview" "overview"] ["Details" "details"]]}]
        [:c/show {:when :tab-overview?}
         [:c/title {:text "Overview" :level 3}]
         [:c/paragraph {:text "The tab strip sets the :tab signal on the server; these panels are shown by reactions over it."}]]
        [:c/show {:when :tab-details?}
         [:c/title {:text "Details" :level 3}]
         [:c/h-box {:gap :md :align :center}
          [:c/paragraph {:text "h-box lays children in a row."}]
          [:c/hyperlink {:href "https://re-com.day8.com.au/" :target "_blank" :label "re-com →"}]]]
        [:c/line {:orientation :horizontal}]
        [:c/border {:rounded? true}
         [:c/scroller {:size :sm}
          [:c/paragraph {:text "A bordered, scrollable region (scroller inside border). Resize the window to see it scroll."}]
          [:c/paragraph {:text "Layout primitives — scroller, border, gap, line — are pure structure; the theme supplies all spacing and rules."}]]]]]

      [:section#sec-feedback.sv-panel
       [:h2 "Feedback" [:span.sv-kw ":progress-bar  :throbber  :alert-list  :info-button"]]
       [:p.sv-desc "A progress bar bound to a numeric field (edit it above-style via the slider), a CSS throbber, a stack of alerts, and an inline info button."]
       [:div.sv-demo
        [:c/h-box {:gap :sm :align :center}
         [:c/slider {:id :progress :label "Progress" :min 0 :max 100 :step 5}]
         [:c/info-button {:signal "progInfo" :info "Drag the slider; the bar below tracks it live over SSE."}]]
        [:c/progress-bar {:id :progress :label "Upload" :striped? true}]
        [:c/v-box {:gap :sm}
         [:c/throbber {:size :regular :label "Working…"}]]
        [:c/alert-list {:label "Notices"
                        :alerts [{:class "alert-warning" :heading "Heads up" :body "Some fields are optional."}
                                 {:class "alert-success" :body "Everything is saved server-side as you type."}]}]]]

      [:section#sec-overlays.sv-panel
       [:h2 "Overlays" [:span.sv-kw ":popover  :modal-panel"]]
       [:p.sv-desc "A popover and a modal. Visibility is local client state (a Datastar signal) toggled with data-show — no server round-trip."]
       [:div.sv-demo
        [:c/h-box {:gap :md :align :center}
         [:c/popover {:signal "tip" :trigger-label "Show tip" :position :below :title "Did you know?"}
          [:span "Every widget here is server-authoritative — this popover is the rare bit of purely-local UI state."]]
         [:c/modal-panel {:signal "demoModal" :title "Hello from a modal" :trigger-label "Open modal"}
          [:p "Modal content rendered as ordinary children. Click the backdrop or × to close."]]]]]

      [:section#sec-viz.sv-panel
       [:h2 "Visualization" [:span.sv-kw ":chart  :calendar"]]
       [:p.sv-desc "A Highcharts line chart driven by the rating slider (drag it above to redraw live) and a CalendarJS week schedule."]
       [:div.sv-demo
        [:c/chart {:id :chart :chart-type :line :x-axis-title "Day" :y-axis-title "Rating"}]
        [:c/calendar {:id :cal :label "Schedule"}]]]

      [:section#sec-people.sv-panel
       [:h2 "Collection" [:span.sv-kw ":collection"]]
       [:p.sv-desc "A repeating group; each item's full name is a per-item derived field (domino event)."]
       [:div.sv-demo
        [:c/collection {:id :people}
         [:c/input-field {:id :first :label "First"}]
         [:c/input-field {:id :last :label "Last"}]
         [:p "Full: " [:c/value {:id :full}]]]]]

      [:section#sec-table.sv-panel
       [:h2 "Table" [:span.sv-kw ":table"]]
       [:p.sv-desc "A collection as a table: add/remove/reorder rows, sort columns, and page."]
       [:div.sv-demo
        [:c/table {:id :tasks
                   :columns [{:path :title :label "Title" :sortable? true
                              :widget :stepvine.components/input-field}
                             {:path :priority :label "Priority" :sortable? true
                              :widget :stepvine.components/input-field}]
                   :can-add-rows? true :can-delete-rows? true :can-move-rows? true
                   :can-clear-table? true :paged? true :page-size 5 :striped? true}]]]

      [:section#sec-actions.sv-panel
       [:h2 "Actions" [:span.sv-kw ":action"]]
       [:p.sv-desc "Trigger a server-side action — here a templated export of the current values."]
       [:div.sv-demo
        [:c/action {:action :summary :label "Export summary"}]
        [:pre {:id "export-result"}]]]

      [:p.sv-presence "Editors online: " [:span {:data-text "$presence"}]]]]]}}}
