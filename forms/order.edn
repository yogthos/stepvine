;; Cascading derived fields. Domino :events form a lazy DAG: an event whose input
;; is ANOTHER event's output re-fires when that output changes, so a single edit
;; ripples through the whole chain. Here the calculated fields cascade
;;
;;     qty, price ─▶ subtotal ─▶ discount ─▶ tax ─▶ total
;;
;; i.e. changing the quantity recomputes the subtotal, which recomputes the
;; discount, which recomputes the tax, which recomputes the total — each
;; calculated field triggers the recalculation of the next. The server pushes
;; every recomputed value to the browser as it settles.
{:id    :order
 :title "Order Calculator"

 :data
 {:model
  [;; inputs the user edits
   [:qty          {:id :qty          :type :number}]
   [:price        {:id :price        :type :number}]
   [:discount-pct {:id :discount-pct :type :number}]
   [:tax-rate     {:id :tax-rate     :type :number}]
   ;; calculated fields (each is an event output AND a downstream event input)
   [:subtotal     {:id :subtotal     :type :number}]
   [:discount     {:id :discount     :type :number}]
   [:tax          {:id :tax          :type :number}]
   [:total        {:id :total        :type :number}]]

  :events
  [;; 1. subtotal = qty × price
   {:id :calc-subtotal
    :inputs  [:qty :price]
    :outputs [:subtotal]
    :handler (fn [{{:keys [qty price]} :inputs}]
               {:subtotal (let [x (* (or qty 0) (or price 0))]
                            (/ (long (+ 0.5 (* x 100))) 100.0))})}
   ;; 2. discount = subtotal × discount% — depends on the calculated subtotal
   {:id :calc-discount
    :inputs  [:subtotal :discount-pct]
    :outputs [:discount]
    :handler (fn [{{:keys [subtotal discount-pct]} :inputs}]
               {:discount (let [x (/ (* (or subtotal 0) (or discount-pct 0)) 100.0)]
                            (/ (long (+ 0.5 (* x 100))) 100.0))})}
   ;; 3. tax = (subtotal − discount) × tax% — depends on TWO calculated fields
   {:id :calc-tax
    :inputs  [:subtotal :discount :tax-rate]
    :outputs [:tax]
    :handler (fn [{{:keys [subtotal discount tax-rate]} :inputs}]
               {:tax (let [taxable (- (or subtotal 0) (or discount 0))
                           x (/ (* taxable (or tax-rate 0)) 100.0)]
                       (/ (long (+ 0.5 (* x 100))) 100.0))})}
   ;; 4. total = subtotal − discount + tax — depends on all three above
   {:id :calc-total
    :inputs  [:subtotal :discount :tax]
    :outputs [:total]
    :handler (fn [{{:keys [subtotal discount tax]} :inputs}]
               {:total (let [x (+ (- (or subtotal 0) (or discount 0)) (or tax 0))]
                         (/ (long (+ 0.5 (* x 100))) 100.0))})}]

  :reactions
  [{:id :free-shipping? :args [:subtotal] :fn (fn [s] (>= (or s 0) 100))}]

  ;; An EFFECT — the engine's outbound signal. When the (derived) total changes,
  ;; the engine fires this; the handler returns an intent the host layer performs
  ;; (here a transient in-app notice). It rides the same DAG as the calc events:
  ;; editing the quantity moves the total, which fires the effect.
  :effects
  [{:on [:total]
    :handler (fn [{:keys [inputs]}]
               (when (> (or (:total inputs) 0) 100)
                 {:kind :notify :message "Large order — flagged for review."}))}]}

 ;; An in-browser HTML/Markdown report (parity): a static snapshot rendered with
 ;; value substitution + transforms (:fmt) + markdown — viewable in the browser.
 :reports
 {:summary
  {:title "Order Summary"
   :body  [:div
           [:markdown "## Order Summary\n\nThank you for your **order**."]
           [:table
            [:tr [:th "Line"] [:th "Amount"]]
            [:tr [:td "Subtotal"] [:td [:val :subtotal {:fmt "$%.2f"}]]]
            [:tr [:td "Discount"] [:td [:val :discount {:fmt "$%.2f"}]]]
            [:tr [:td "Tax"]      [:td [:val :tax {:fmt "$%.2f"}]]]
            [:tr [:td [:strong "Total"]] [:td [:strong [:val :total {:fmt "$%.2f"}]]]]]]}}

 :views
 {:default
  {:title "Order Calculator"
   :opts  {:widget-namespaces {"c" "stepvine.components"}}
   :markup
   [:c/form {}
    [:h1 "Order Calculator"]
    [:p "Edit any input — quantity, price, discount or tax — and watch the totals "
     "cascade: subtotal → discount → tax → total."]
    [:c/input-field {:label "Quantity"        :id :qty}]
    [:c/input-field {:label "Unit price ($)"   :id :price}]
    [:c/input-field {:label "Discount (%)"     :id :discount-pct}]
    [:c/input-field {:label "Tax rate (%)"     :id :tax-rate}]
    [:hr]
    ;; calculated money fields, shown read-only and currency-formatted live via
    ;; :fmt (printf-style) — no raw float noise
    [:c/labeled-value {:label "Subtotal" :id :subtotal :fmt "$%.2f" :default "$0.00"}]
    [:c/labeled-value {:label "Discount" :id :discount :fmt "$%.2f" :default "$0.00"}]
    [:c/labeled-value {:label "Tax"      :id :tax      :fmt "$%.2f" :default "$0.00"}]
    [:c/labeled-value {:label "Total"    :id :total    :fmt "$%.2f" :default "$0.00"}]
    [:c/show {:when :free-shipping?}
     [:p.alert.alert-success "Free shipping — subtotal is over $100."]]
    [:p [:c/hyperlink {:doc-path "reports/summary" :label "View order summary report →"
                       :target "_blank"}]]
    [:p.presence "Editors online: " [:span {:data-text "$presence"}]]]}}}
