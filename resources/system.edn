{:system/env
 #profile {:dev  :dev
           :test :test
           :prod :prod}
 
 
 
 

 :server/http
 {:port    #long #or [#env PORT 3000]
  :host    #or [#env HTTP_HOST "0.0.0.0"]
  :handler #ig/ref :handler/ring}

 :handler/ring
 {:router                #ig/ref :router/core
  :api-path              "/api"
  :cookie-secret         #or [#env COOKIE_SECRET "VLNVIOXTFWCGBPPK"]
  ;; from ring.middleware.defaults. anti-forgery `false` by default because services may not require it
  :site-defaults-config  {:params    {:urlencoded true
                                      :multipart  true
                                      :nested     true
                                      :keywordize true}
                          :cookies   true
                          :session   {:flash true
                                      :cookie-name "yogthos.stepvine"
                                      :cookie-attrs {:max-age     86400
                                                     :http-only   true
                                                     :same-site   :strict}}
                          :security  {:anti-forgery   false
                                      :xss-protection {:enable? true, :mode :block}
                                      :frame-options  :sameorigin
                                      :content-type-options :nosniff}
                          :static    {:resources "public"}
                          :responses {:not-modified-responses true
                                      :absolute-redirects     true
                                      :content-types          true
                                      :default-charset        "utf-8"}}}

 :reitit.routes/api
 {:base-path "/api"
  :env       #ig/ref :system/env}

 :reitit.routes/pages
 {:env            #ig/ref :system/env
  :forms          #ig/ref :store/forms
  :documents      #ig/ref :store/documents
  :session        #ig/ref :session/manager
  :hub            #ig/ref :datastar/hub
  :options-store  #ig/ref :store/options
  :patient-client #ig/ref :clients/patient
  :users          #ig/ref :store/users
  :audit          #ig/ref :store/audit
  :access         #ig/ref :store/access
  :reports-dir    #or [#env REPORTS_DIR "data/reports"]
  ;; OAuth2/OIDC providers (§15.13). Dev/test ship a self-contained :mock provider
  ;; that short-circuits the external round trip; prod configures real providers
  ;; (client-id/secret/authorize-url/token-url) and must NOT expose :mock.
  :oauth #profile {:dev  {:providers {:mock {:mock? true :label "Demo SSO"
                                             :mock-profile {:provider :mock :subject "mock-sub-1"
                                                            :email "demo@example.com" :name "Demo User"}}}}
                   :test {:providers {:mock {:mock? true :label "Demo SSO"
                                             :mock-profile {:provider :mock :subject "mock-sub-1"
                                                            :email "demo@example.com" :name "Demo User"}}}}
                   :prod {:providers {}}}}

 ;; --- Form/app engine ------------------------------------------------------
 ;; Reusable definition partials, spliced into forms at serve time (§15.9)
 :store/partials
 {:dir #or [#env PARTIALS_DIR "partials"]}

 ;; The app store (EDN + CSS). Dev/prod run on the embedded SQLite backend
 ;; (`forms` working table + `form_versions` archive), seeded once from the disk
 ;; `forms/` directory; thereafter apps live in the DB and are editable live. Tests
 ;; use the in-memory map backend (duratom version archive). Set :backend :atom +
 ;; :versions-file to run dev on disk EDN + a duratom archive instead.
 :store/forms
 {:partials      #ig/ref :store/partials
  :dir           #or [#env FORMS_DIR "forms"]            ; seed source
  :backend       #profile {:dev :sql :test :atom :prod :sql}
  :db-file       #or [#env APPS_DB "data/apps.db"]
  :versions-file #profile {:dev  "data/form-versions.edn"
                           :test nil
                           :prod #or [#env FORM_VERSIONS_FILE "data/form-versions.edn"]}}

 ;; DB-sourced dropdown options live on disk, one EDN file per source
 :store/options
 {:dir #or [#env OPTIONS_DIR "options"]}

 ;; External service stub: a small patient directory
 :clients/patient
 {:directory {"p1" {:given "Ada"  :family "Lovelace" :dob "1815-12-10"}
              "p2" {:given "Alan" :family "Turing"   :dob "1912-06-23"}}}

 ;; Document instances; duratom-persisted on disk in dev/prod, in-memory for tests
 ;; Document store: embedded SQLite query backend (§15.13) in dev/prod, in-memory
 ;; atom for tests. (Set :backend :atom + :file to fall back to the duratom EDN store.)
 :store/documents
 {:backend #profile {:dev :sql :test :atom :prod :sql}
  :db-file #or [#env DOCUMENTS_DB "data/documents.db"]}

 ;; Append-only audit log (§15.4); duratom on disk in dev/prod, in-memory for tests
 :store/audit
 {:file #profile {:dev  "data/audit.edn"
                  :test nil
                  :prod #or [#env AUDIT_FILE "data/audit.edn"]}}

 ;; Role-based form access (admin UI): {form-id #{roles}}
 :store/access
 {:file #profile {:dev  "data/access.edn"
                  :test nil
                  :prod #or [#env ACCESS_FILE "data/access.edn"]}}

 ;; User accounts; duratom-persisted in dev/prod, in-memory for tests.
 ;; A dev admin (admin/admin) is seeded when the store is empty.
 :store/users
 {:file #profile {:dev  "data/users.edn"
                  :test nil
                  :prod #or [#env USERS_FILE "data/users.edn"]}}

 :datastar/hub
 {}

 ;; Periodic keep-alive: detects dropped SSE clients (the ring adapter only
 ;; notices a broken connection on a failed write) so their thread + locks are
 ;; freed. Datastar handles client-side reconnect (retryInterval/Scaler/MaxCount).
 :datastar/heartbeat
 {:hub         #ig/ref :datastar/hub
  :interval-ms #long #or [#env HEARTBEAT_MS 20000]}

 :session/manager
 {:documents #ig/ref :store/documents
  :hub       #ig/ref :datastar/hub}

 :router/routes
 {:routes #ig/refset :reitit/routes}

 :router/core
 {:routes #ig/ref :router/routes
  :env #ig/ref :system/env} }
